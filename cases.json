    {
      "_section": "═══════════════════ Phase 2 行为评测（多轮 case + 8 维度）═══════════════════"
    },
    {
      "case_id": "P2-CONF-WEB-FULL",
      "phase": "p2",
      "category": "integration",
      "tags": [
        "conference",
        "web",
        "multi-turn",
        "full"
      ],
      "description": "Conference Web 完整集成：路由触发 + 一级路由 + 追问平台 + 上报顺序 + 会话状态",
      "turns": [
        {
          "user": "我想实现一个支持千人参会的会议模块，要求其具备完备的会控管理功能和麦位管理功能，还需要支持屏幕共享，一个房间内只允许一个人开启。",
          "expect": {
            "route_triggered": {
              "skill": "trtc"
            },
            "reporting_called": {
              "scripts": [
                "reporting.py prompt",
                "reporting.py context"
              ]
            },
            "clarification_raised": {
              "topics": [
                "platform"
              ]
            }
          }
        },
        {
          "user": "Web 平台",
          "expect": {
            "route_level1": {
              "target": "trtc-conference",
              "must_not": [
                "trtc-docs",
                "trtc-ai-service"
              ]
            },
            "session_state": {
              "status": "active",
              "product": "conference",
              "platform": "web"
            }
          }
        }
      ],
      "case_level_expect": {
        "reporting_before_clarification": true
      }
    },
    {
      "case_id": "P2-CONF-WEB-NO-UI",
      "phase": "p2",
      "category": "integration",
      "tags": [
        "conference",
        "web",
        "single-turn",
        "no-ui"
      ],
      "description": "明确说不要 UI 时仍走 conference 路径",
      "turns": [
        {
          "user": "帮我用 TRTC 搭建一个会议应用，不需要 UI 组件，只要业务逻辑代码。",
          "expect": {
            "route_level1": {
              "target": "trtc-conference",
              "must_not": [
                "trtc-docs"
              ]
            },
            "reporting_called": {
              "scripts": [
                "reporting.py prompt"
              ]
            },
            "clarification_raised": {
              "topics": [
                "platform"
              ]
            }
          }
        }
      ]
    },
    {
      "case_id": "P2-DOCS-ERRCODE",
      "phase": "p2",
      "category": "faq",
      "tags": [
        "error-code",
        "smoke",
        "single-turn"
      ],
      "description": "错误码查询应直奔 trtc-docs，触发 query_classifier 分类为 slice-lookup",
      "turns": [
        {
          "user": "TRTC 错误码 -1002 是什么意思？",
          "expect": {
            "route_level1": {
              "target": "trtc-docs",
              "must_not": [
