        "claude-code"
      ],
      "description": "claude-code 全量资产分发到位"
    },
    {
      "case_id": "P1-INSTALL-CURSOR",
      "phase": "p1",
      "category": "install",
      "ide": "cursor",
      "tags": [
        "install",
