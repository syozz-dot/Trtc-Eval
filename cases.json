            "session_state": {
              "status": "active",
              "product": "conference"
            }
          }
        },
        {
          "user": "继续。",
          "expect": {
            "session_state": {
              "resumed_from_guard": true,
              "reason": "Session Guard 应直接恢复，不重走分类"
            },
            "tools_called": {
              "must_not": [
                "query_classifier"
              ],
              "reason": "session 已 active 不应再分类"
            }
          }
        }
      ]
    }
  ]
}
