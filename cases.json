        "cursor"
      ],
      "description": "cursor 全量资产分发到位（含 cursor-adapter）"
    },
    {
      "case_id": "P1-INSTALL-CODEBUDDY",
      "phase": "p1",
      "category": "install",
      "ide": "codebuddy",
      "tags": [
        "install",
        "smoke",
        "codebuddy"
      ],
      "description": "codebuddy 全量资产分发到位（与 claude 共用 hooks.json）"
