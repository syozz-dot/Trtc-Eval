{
  "version": "2.0.0",
  "description": "TRTC skill 评测用例集 v2 — 支持全量资产 P1 + 多轮 P2 8 维度 + IDE 能力差异化",
  "_doc": {
    "structure": "顶层四段：asset_catalog（资产清单）+ ide_profiles（各 IDE 能力 + 安装路径）+ cases（用例集）+ obs_keys（观察点字典）",
    "p1_principle": "P1 用例引用 asset_catalog 里的资产组，不在 case 里硬编码路径；按 IDE 能力差异引用不同的 asset_groups",
    "p2_principle": "P2 用例支持多轮（turns 数组），每轮可独立标注期望；用 ide_capabilities 字段标注观察点需要的 IDE 能力，score.py 据此跳过不可测维度"
  },
  "asset_catalog": {
    "_doc": "npx add 之后每个 IDE 目录（.claude / .cursor / .codebuddy / .codex）下的资产清单。所有路径以 IDE 目录为根，check_install.py 会拼上 ide_profiles[ide].install_root_prefix 得到完整路径。4 IDE 分发的资产完全一致（4 IDE 严格镜像）。",
    "skills_root": {
      "description": "5 个域 skill 的 SKILL.md（主调度 + 4 域）+ chat/docs 子 skill",
      "files": [
        "skills/trtc/SKILL.md",
        "skills/trtc-conference/SKILL.md",
        "skills/trtc-docs/SKILL.md",
        "skills/trtc-ai-service/SKILL.md",
        "skills/trtc-chat/SKILL.md"
      ]
    },
    "hooks_scripts": {
      "description": "5 个 hook 脚本：越界读 / 阶段门控 / 越界写 / 强制 apply / 会议业务决策",
      "files": [
        "skills/trtc/hooks/gate_slice_read.py",
        "skills/trtc/hooks/topic_phase_gate.py",
        "skills/trtc/hooks/gate_slice_write.py",
        "skills/trtc/hooks/stop_require_apply_evidence.py",
        "skills/trtc-conference/hooks/pretooluse_require_business_decisions.py"
      ]
    },
    "hooks_settings_claude_style": {
      "description": "Claude / CodeBuddy 的 hook 注册（settings.json 里的 hooks 段）",
      "files": [
        "settings.json"
      ]
    },
    "hooks_settings_cursor_style": {
      "description": "Cursor / Codex 的 hook 注册（hooks.json 独立文件）",
      "files": [
        "hooks.json"
      ]
    },
    "hooks_dir": {
      "description": "IDE 级 hooks 目录（含 cursor-adapter.py 转译层）",
      "files": [
        "hooks/hooks.json",
        "hooks/hooks-cursor.json",
        "hooks/cursor-adapter.py"
      ]
    },
    "hooks_dir_cursor": {
      "description": "Cursor plugin 命名空间下的 hooks（比其他 IDE 多一层 trtc-agent-skills/）",
      "files": [
        "hooks/trtc-agent-skills/hooks.json",
        "hooks/trtc-agent-skills/hooks-cursor.json",
        "hooks/trtc-agent-skills/cursor-adapter.py"
      ]
    },
    "shared_tools": {
      "description": "trtc 主 skill 的共享工具层（15 个 Python 模块）",
      "files": [
        "skills/trtc/tools/__init__.py",
        "skills/trtc/tools/reporting.py",
        "skills/trtc/tools/reporting_v2.py",
        "skills/trtc/tools/session.py",
        "skills/trtc/tools/apply.py",
        "skills/trtc/tools/flow.py",
        "skills/trtc/tools/docs.py",
        "skills/trtc/tools/docsbot.py",
        "skills/trtc/tools/kb.py",
        "skills/trtc/tools/search.py",
        "skills/trtc/tools/query_classifier.py",
        "skills/trtc/tools/state_machine.py",
        "skills/trtc/tools/init_slice_queue.py",
        "skills/trtc/tools/next_slice.py",
        "skills/trtc/tools/finalize_session.py"
      ]
    },
    "knowledge_base": {
      "description": "共享知识库：产品清单 / scenario / slice 规范 / 工具关键词",
      "files": [
        "knowledge-base/products.yaml",
        "knowledge-base/scenario-spec.md",
        "knowledge-base/slice-spec.md",
        "knowledge-base/platform-slice-template.md",
        "knowledge-base/tooling/aliases.yaml",
        "knowledge-base/tooling/symptom-keywords.yaml",
        "knowledge-base/tooling/intent-signals.yaml"
      ]
    },
    "conference_bundle": {
      "description": "trtc-conference 集成包：flows / playbooks / references / templates / tests",
      "files": [
        "skills/trtc-conference/flows",
        "skills/trtc-conference/playbooks",
        "skills/trtc-conference/references",
        "skills/trtc-conference/templates",
        "skills/trtc-conference/tests",
        "skills/trtc-conference/tools",
        "skills/trtc-conference/verify_lib"
      ]
    }
  },
  "ide_profiles": {
    "_doc": "各 IDE 的安装根目录 + 能力清单 + headless CLI 配置。install_root_prefix 是 IDE 目录本身（含 4 IDE 各自独立的完整 skill 分发）。asset_catalog 中的相对路径都以此为基点。",
    "claude-code": {
      "install_root_prefix": ".claude",
      "manifest_style": "settings.json",
      "asset_groups": [
        "skills_root",
        "hooks_scripts",
        "hooks_settings_claude_style",
        "hooks_dir",
        "shared_tools",
        "knowledge_base",
        "conference_bundle"
      ],
      "capabilities": [
        "headless",
        "tool_use_events",
        "hooks",
        "session_file",
        "trace"
      ],
      "cli": {
        "binary": "claude",
        "args": [
          "-p",
          "--output-format",
          "stream-json",
          "--verbose",
          "--dangerously-skip-permissions"
        ],
        "prompt_position": "arg",
        "resume_args": [
          "--resume",
          "{session_id}"
        ],
        "event_dialect": "claude",
        "session_id_source": "system.init.session_id",
        "auth": "ANTHROPIC_API_KEY or local /login"
      },
      "transcript_path": "stdout (stream-json)"
    },
    "cursor": {
      "install_root_prefix": ".cursor",
      "manifest_style": "hooks.json",
      "asset_groups": [
        "skills_root",
        "hooks_scripts",
        "hooks_settings_cursor_style",
        "hooks_dir_cursor",
        "shared_tools",
        "knowledge_base",
        "conference_bundle"
      ],
      "capabilities": [
        "headless",
        "tool_use_events",
        "hooks",
        "session_file"
      ],
      "cli": {
        "binary": "cursor-agent",
        "args": [
          "-p",
          "--output-format",
          "stream-json",
          "--force"
        ],
        "prompt_position": "arg",
        "resume_args": [
          "--resume",
          "{session_id}"
        ],
        "event_dialect": "cursor",
        "session_id_source": "system.init.session_id",
        "auth": "CURSOR_API_KEY or cursor-agent login"
      },
      "transcript_path": "stdout (stream-json)"
    },
    "codebuddy": {
      "install_root_prefix": ".codebuddy",
      "manifest_style": "settings.json",
      "asset_groups": [
        "skills_root",
        "hooks_scripts",
        "hooks_settings_claude_style",
        "hooks_dir",
        "shared_tools",
        "knowledge_base",
        "conference_bundle"
      ],
      "capabilities": [
        "headless",
        "tool_use_events",
        "hooks",
        "session_file",
        "trace"
      ],
      "cli": {
        "binary": "codebuddy",
        "args": [
          "-p",
          "--output-format",
          "stream-json",
          "-y"
        ],
        "prompt_position": "arg",
        "resume_args": [
          "--resume",
          "{session_id}"
        ],
        "event_dialect": "claude",
        "session_id_source": "system.init.session_id",
        "auth": "Login required (UI or env var)"
      },
      "transcript_path": "stdout (stream-json)"
    },
    "codex": {
      "install_root_prefix": ".codex",
      "manifest_style": "hooks.json",
      "asset_groups": [
        "skills_root",
        "hooks_scripts",
        "hooks_settings_cursor_style",
        "hooks_dir",
        "shared_tools",
        "knowledge_base",
        "conference_bundle"
      ],
      "capabilities": [
        "headless",
        "tool_use_events",
        "hooks",
        "session_file",
        "trace"
      ],
      "cli": {
        "binary": "codex",
        "args": [
          "exec",
          "--json",
          "--skip-git-repo-check",
          "--sandbox",
          "danger-full-access"
        ],
        "prompt_position": "arg",
        "resume_subcommand": [
          "exec",
          "resume"
        ],
        "resume_args": [
          "--json",
          "--skip-git-repo-check",
          "--sandbox",
          "danger-full-access",
          "{session_id}"
        ],
        "event_dialect": "codex",
        "session_id_source": "thread.started.thread_id",
        "auth": "codex login"
      },
      "transcript_path": "stdout (JSONL: thread.started / turn.* / item.*)"
    }
  },
  "obs_keys": {
    "_doc": "P2 的 8 个评测维度。每个 case 的 turn.expect 引用这些 key；score.py 按维度算通过率。requires 字段标注此维度需要 IDE 提供哪些能力，缺失则跳过。",
    "route_triggered": {
      "label": "路由触发：trtc skill 是否被加载激活",
      "requires": [
        "headless",
        "tool_use_events"
      ]
    },
    "route_level1": {
      "label": "一级路由：主调度 skill 选对了下游域 skill（conference / docs / ai-service / chat）",
      "requires": [
        "headless",
        "tool_use_events"
      ]
    },
    "route_level2": {
      "label": "二级路由：域 skill 内部走对子路径（如 chat 的 Path A/B/C/D）",
      "requires": [
        "headless",
        "tool_use_events"
      ]
    },
    "clarification_raised": {
      "label": "主动追问：信息不全时反问平台 / 产品",
      "requires": [
        "headless"
      ]
    },
    "reporting_called": {
      "label": "上报埋点：prompt 上报 + 业务事件 + MCP 调用",
      "requires": [
        "headless",
        "tool_use_events"
      ]
    },
    "hooks_guarded": {
      "label": "Hooks 守门：错误时机的读 / 写 / 停止被 hook 拦截",
      "requires": [
        "headless",
        "hooks"
      ]
    },
    "tools_called": {
      "label": "工具调用：query_classifier / search / docs 被正确调用",
      "requires": [
        "headless",
        "tool_use_events"
      ]
    },
    "session_state": {
      "label": "会话与边界：.trtc-session.yaml 流转正确 + 不支持产品不瞎吐代码",
      "requires": [
        "headless",
        "session_file"
      ]
    },
    "trace_assertions": {
      "label": "[Phase 3] 白盒 trace 断言：session.write / flow.enter / state_machine / hook_decision / tool_call 事件是否符合预期",
      "requires": [
        "headless",
        "trace"
      ]
    }
  },
  "cases": [
    {
      "_section": "═══════════════════ Phase 1 安装检查（4 个 IDE 各 1 条）═══════════════════"
    },
