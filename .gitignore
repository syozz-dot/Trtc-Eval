# Python
__pycache__/
*.pyc
.pytest_cache/

# Eval runs — results.yaml + summary.json ARE committed (CI scores them);
# transcripts and their turns are opt-in (may contain sensitive prompts/output).
# If you want to commit them, remove the ignore rule below for that run dir.
eval-runs/**/transcripts/

# Corpus smoke transcripts are opt-in whitelisted — the 8 seed cases are
# generic product questions (no PII), and coverage_report.py needs them
# as input for bucket_classifier analysis in CI.
!eval-runs/corpus-smoke-*/transcripts/
!eval-runs/corpus-smoke-*/transcripts/**

# Golden fixtures for parser regression — DO commit these
!fixtures/
!fixtures/**

# macOS
.DS_Store

# Locally-installed skill target (from npx add for testing)
.claude/
.cursor/
.codebuddy/
.codex/
.agents/
